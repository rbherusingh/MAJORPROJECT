<% layout("/layouts/boilerplate") %>
<% let activeCategory = locals.category || ""; %>

   <style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }
    .filter {
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
    }

    .active-filter {
  opacity: 1;
  border-bottom: 2px solid black;
}

.tax-info {
    display: none;
}

.tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 2rem;
    display: flex;
    align-items: center;
}

   </style>

    <div id="filters">
     <div class="filter <%= activeCategory === 'trending' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=trending'">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
     </div>
   
   
     <div class="filter <%= activeCategory === 'rooms' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=rooms'">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
     </div>

     <div class="filter <%= activeCategory === 'iconic cities' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=iconic%20cities'">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
     </div>

     <div class="filter <%= activeCategory === 'mountains' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=mountains'">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
     </div>

     <div class="filter <%= activeCategory === 'castles' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=castles'">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
     </div>

     <div class="filter <%= activeCategory === 'amazing pools' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=amazing%20pools'">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
     </div>

      
     <div class="filter <%= activeCategory === 'camping' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=camping'">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping </p>
     </div>

     <div class="filter <%= activeCategory === 'farms' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=farms'">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
     </div>

     <div class="filter <%= activeCategory === 'arctic' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=arctic'">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
     </div>

     <div class="filter <%= activeCategory === 'farms' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=farms'">
      <div><i class="fa-solid fa-igloo"></i></div>
      <p>Domes</p>
     </div>

     <div class="filter <%= activeCategory === 'arctic' ? 'active-filter' : '' %>" onclick="window.location.href='/listings?category=arctic'">
      <div><i class="fa-solid fa-sailboat"></i></div>
      <p>Boats</p>
     </div>


     <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input 
          class="form-check-input" 
          type="checkbox" 
          role="switch" 
          id="switchCheckDefault">
           <label class="form-check-label" for="switchCheckDefault">Display totle after taxes</label>
        </div>
     </div>
    </div>
 
     <% if(allListings.length === 0) { %>
        <div class="text-center mt-5">
            <h3>No listings found!</h3>
            <p>Try searching for something else.</p>
            <a href="/listings" class="btn btn-dark">View All Listings</a>
        </div>
    <% } else { %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
           <% for(let listing of allListings) { %>
       <a href="/listings/<%= listing._id %>" class="listing-link">



<div class="card col listing-card">
  <img 
  src="<%= listing.image.url %>"
   class="card-img-top"
    alt="listing_image"
     style="height: 20rem;"
     />
      <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
        <br><%= listing.title %></b><br/>
        
        &#8377;<%= listing.price.toLocaleString("en-IN") %> /night
        <i class="tax-info"> &nbsp; &nbsp;+18 GST</i>
       </p>
  </div>
</div>
</a>
<% } %>
    </div>
<% } %>

    <script>
    let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (info of taxInfo) {
           if (info.style.display != "inline") {
            info.style.display = "inline";
           }else {
            info.style.display = "none";
           }
        }
        });
    
</script>
    
   

